# Build the cu12.9 (CUDA 12.9) slice of verl's uv-managed multi-backend image.
#
# verl uses one universal uv.lock for the whole project; this Dockerfile
# builds its cu12.9 (CUDA 12.9 / torch 2.9.1) slice. Backends are PEP 621
# extras, and mutually exclusive ones are declared in pyproject.toml's
# [tool.uv].conflicts, so a single committed uv.lock resolves them all:
#
#   * cu12.9 (this file, base nvidia/cuda:12.9.1): veomni, nemoautomodel —
#     both on torch 2.9.1 / cu129. They source-build flash-attn 2.8.3 (there
#     is no cu129 prebuilt wheel, and uv can't fork a second direct URL —
#     uv#13073). veomni and nemoautomodel share this torch world but pin it
#     differently, so they conflict — pick exactly one at run time.
#   * The torch-2.11 / cu13.0 backends (vllm, sglang, fsdp, megatron, cpu)
#     live in the SAME uv.lock but are baked by docker/Dockerfile.uv.cu130.
#   * DEFERRED — trtllm (tensorrt-llm) is a CUDA-13 RC sdist whose dependency
#     tree explodes uv's resolver, so it is commented out in pyproject.toml.
#     When it ships a stable release it belongs in the cu13.0 image (it needs
#     cuda-python >= 13), not here.
#
# At build time we BAKE the cu12.9 uv cache — the veomni & nemoautomodel wheels
# and built artifacts (including the source-built flash-attn), resolved from
# the committed uv.lock — into the image (the `prefetch cu129` stage). The
# image does NOT bake a fixed .venv. At container start you materialize the
# backend you want with `manage_envs.py sync` — it `uv sync`s the requested
# extra from that baked cache (fast / offline) into a single project venv at
# /workspace/verl/.venv (already on PATH). There is no per-backend venv
# and no Ray py_executable switching — every role runs from that one .venv.
# The uv flow is x86_64 Linux + Python 3.12 only — Ascend NPU and aarch64 GPU
# variants are out of scope (for Ascend see docker/ascend/... instead).
#
# The base layer is a superset of the "basic" stages of the upstream
# `sglang/docker/Dockerfile` and `vllm/docker/Dockerfile`, so the resulting
# image satisfies the system-level prerequisites of both inference engines:
#
#   - sglang basic: full RDMA/InfiniBand + OpenMPI + NUMA + dev libs +
#                   GDRCopy + IBGDA symlink + locale (Ubuntu 24.04).
#   - vllm  basic: gcc-10 alternatives, uv-driven Python install, the
#                  uv tunables (UV_HTTP_TIMEOUT / UV_INDEX_STRATEGY /
#                  UV_LINK_MODE) and CUDA forward-compat toggle.
#
# The build context is the verl repo (it COPYs `.`, which must include the
# committed uv.lock):
#
#     docker build -f docker/Dockerfile.uv.cu129 -t verl:uv-cu129 .
#
# Pick the backend at RUN time (not build time) by syncing it yourself — one
# of veomni / nemoautomodel (they conflict; see [tool.uv].conflicts):
#
#     docker run --rm -it --gpus all verl:uv-cu129 bash
#     # then, inside the container:
#     python3 manage_envs.py sync veomni -- --frozen
#     python3 -m verl.trainer.main_ppo ...
#
# Optional named stages:
#   * --target=prefetch : just the baked cu12.9 uv cache, no source.
#   * --target=lock     : regenerate the (whole, universal) uv.lock.
#
#     docker build -f docker/Dockerfile.uv.cu129 --target=lock -t verl:uv-cu129-lock .
#
# Useful build args:
#
#     --build-arg MAX_JOBS=128                   # bump for big build hosts
#     --build-arg CUDA_VERSION=12.9.1            # alternative CUDA dev base
#     --build-arg UBUNTU_MIRROR=...              # apt mirror (sglang-style)
#     --build-arg PIP_DEFAULT_INDEX=...          # pip global index URL
#     --build-arg GITHUB_ARTIFACTORY=github.com  # github mirror
#
# Build with BuildKit. The `prefetch` stage bakes the uv cache into the image
# (deliberately no cache mount), so the runtime `uv sync` is offline; the
# `lock` and apt steps still use BuildKit cache mounts for faster rebuilds.
# See the "Install from the uv image" section in docs/start/install.rst.

ARG CUDA_VERSION=12.9.1
FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu24.04 AS base

ARG CUDA_VERSION
ARG TARGETARCH
ARG DEBIAN_FRONTEND=noninteractive

# Build parallelism for source-built packages. The cu12.9 backends (veomni /
# nemoautomodel) source-build flash-attn 2.8.3 against torch 2.9.1 — there is
# no cu129 prebuilt wheel and uv can't fork a second direct URL (uv#13073) —
# and that nvcc compile honors MAX_JOBS. 32 is conservative and survives most
# CI hosts; raise via --build-arg MAX_JOBS=128 on big machines.
ARG MAX_JOBS=32
ENV MAX_JOBS=${MAX_JOBS}

# cuDNN / NCCL — see https://developer.nvidia.com/cudnn-downloads
# These ARGs control the apt deb versions installed below and MUST match
# whatever uv resolves into uv.lock for the cu12.9 / torch-2.9.1 fork. The
# backend extras don't pin cuDNN / NCCL — torch's wheel pins them transitively
# (torch 2.9.1+cu129 -> nvidia-nccl-cu12==2.27.5), except we override
# nvidia-cudnn-cu12==9.16.0.29 in pyproject.toml's
# [tool.uv].override-dependencies to clear the torch 2.9.1 conv3d bug
# (https://github.com/pytorch/pytorch/issues/168167). After a torch/cudnn bump
# and re-running `python manage_envs.py lock`, grep the resolved versions out
# of uv.lock and update these ARGs:
#
#     grep -E 'nvidia-(cudnn|nccl)-cu12' uv.lock
ARG CUDNN_VERSION=9.16.0.29-1
ARG NCCL_VERSION=2.27.5-1

# Source to build from. Override VERL_REF for tags / commits.
ARG VERL_REPO=https://github.com/verl-project/verl.git
ARG VERL_REF=main

# Mirrors / index overrides (kept compatible with the sglang/vllm Dockerfiles).
ARG UBUNTU_MIRROR
ARG PIP_DEFAULT_INDEX
ARG GITHUB_ARTIFACTORY=github.com
ARG GDRCOPY_VERSION=2.5.1

ENV CUDA_HOME=/usr/local/cuda \
    GDRCOPY_HOME=/usr/src/gdrdrv-${GDRCOPY_VERSION}/

# Add GKE default lib and bin locations (mirrors vllm + sglang base layers).
ENV PATH="${PATH}:/usr/local/nvidia/bin" \
    LD_LIBRARY_PATH="${LD_LIBRARY_PATH}:/usr/local/nvidia/lib:/usr/local/nvidia/lib64"

# Replace Ubuntu sources if a mirror was supplied (sglang-style override).
RUN if [ -n "${UBUNTU_MIRROR}" ]; then \
        find /etc/apt -name '*.list' -o -name '*.sources' | xargs -r \
            sed -i "s|http://.*archive.ubuntu.com|${UBUNTU_MIRROR}|g; s|http://.*security.ubuntu.com|${UBUNTU_MIRROR}|g"; \
    fi

# ---------------------------------------------------------------------------
# System dependencies — superset of `sglang/docker/Dockerfile` (lines 60-127)
# and `vllm/docker/Dockerfile` (lines 100-114) basic stages.
# ---------------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt,id=verl-uv-apt \
    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        software-properties-common \
        netcat-openbsd \
        kmod \
        unzip \
        openssh-client \
        openssh-server \
        sudo \
        curl \
        wget \
        lsof \
        locales \
        vim \
        build-essential \
        ccache \
        cmake \
        perl \
        patchelf \
        git \
        git-lfs \
        gcc-10 \
        g++-10 \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        libopenmpi-dev \
        libnuma1 \
        libnuma-dev \
        numactl \
        ffmpeg \
        libibverbs-dev \
        libibverbs1 \
        libibumad3 \
        librdmacm-dev \
        librdmacm1 \
        libnl-3-200 \
        libnl-route-3-200 \
        libnl-route-3-dev \
        libnl-3-dev \
        ibverbs-providers \
        infiniband-diags \
        perftest \
        libgoogle-glog-dev \
        libgtest-dev \
        libjsoncpp-dev \
        libunwind-dev \
        libboost-all-dev \
        libssl-dev \
        libgrpc-dev \
        libgrpc++-dev \
        libprotobuf-dev \
        protobuf-compiler \
        protobuf-compiler-grpc \
        pybind11-dev \
        libhiredis-dev \
        libcurl4-openssl-dev \
        libczmq4 \
        libczmq-dev \
        libfabric-dev \
        devscripts \
        debhelper \
        fakeroot \
        dkms \
        check \
        libsubunit0 \
        libsubunit-dev \
    && update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-10 110 --slave /usr/bin/g++ g++ /usr/bin/g++-10 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Generate locale (sglang base layer).
RUN locale-gen en_US.UTF-8
ENV LANG=en_US.UTF-8 \
    LANGUAGE=en_US:en \
    LC_ALL=en_US.UTF-8

# ---------------------------------------------------------------------------
# cuDNN + NCCL — actively installed following https://developer.nvidia.com/cudnn-downloads
# The base image is -devel (no cuDNN); we install it explicitly so the version
# is visible, pinned, and reproducible. When cu12.9 is re-enabled these system
# libs must match the nvidia-cudnn-cu12 / nvidia-nccl-cu12 pip wheels resolved
# into uv.lock (CUDNN_VERSION / NCCL_VERSION ARGs above).
# ---------------------------------------------------------------------------
RUN CUDA_VERSION_MAJOR=$(echo ${CUDA_VERSION} | cut -d '.' -f 1) \
    && apt-get update && apt-get install -y --no-install-recommends --allow-change-held-packages \
        libcudnn9-cuda-${CUDA_VERSION_MAJOR}=${CUDNN_VERSION} \
        libcudnn9-dev-cuda-${CUDA_VERSION_MAJOR}=${CUDNN_VERSION} \
        libnccl2=${NCCL_VERSION}+cuda${CUDA_VERSION%.*} \
        libnccl-dev=${NCCL_VERSION}+cuda${CUDA_VERSION%.*} \
    && rm -rf /var/lib/apt/lists/* \
    && echo "=== Installed cuDNN $(dpkg-query -W -f='${Version}' libcudnn9-cuda-${CUDA_VERSION_MAJOR}) ===" \
    && echo "=== Installed NCCL  $(dpkg-query -W -f='${Version}' libnccl2) ==="

# Override pip global index if requested.
RUN if [ -n "${PIP_DEFAULT_INDEX}" ]; then \
        python3 -m pip config --global set global.index-url "${PIP_DEFAULT_INDEX}" || true; \
    fi

# ---------------------------------------------------------------------------
# GDRCopy — pulled from sglang base. Required by DeepEP / GPUDirect on
# both sglang and vllm runtime stacks.
# ---------------------------------------------------------------------------
RUN mkdir -p /tmp/gdrcopy && cd /tmp \
    && curl --retry 3 --retry-delay 2 -fsSL -o v${GDRCOPY_VERSION}.tar.gz \
        https://${GITHUB_ARTIFACTORY}/NVIDIA/gdrcopy/archive/refs/tags/v${GDRCOPY_VERSION}.tar.gz \
    && tar -xzf v${GDRCOPY_VERSION}.tar.gz && rm v${GDRCOPY_VERSION}.tar.gz \
    && cd gdrcopy-${GDRCOPY_VERSION}/packages \
    && CUDA=/usr/local/cuda ./build-deb-packages.sh \
    && dpkg -i gdrdrv-dkms_*.deb libgdrapi_*.deb gdrcopy-tests_*.deb gdrcopy_*.deb \
    && cd / && rm -rf /tmp/gdrcopy

# DeepEP IBGDA symlink fix (sglang base).
RUN ln -sf /usr/lib/$(uname -m)-linux-gnu/libmlx5.so.1 /usr/lib/$(uname -m)-linux-gnu/libmlx5.so

# ---------------------------------------------------------------------------
# uv — single static binary. We bake the cu12.9 uv cache from the committed
# uv.lock via manage_envs.py (the `prefetch cu129` stage); at run time you sync
# the backend you want into .venv from it with `manage_envs.py sync`. Put uv on
# PATH and copy across the uv tunables that vllm sets.
# ---------------------------------------------------------------------------
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh

# UV_CACHE_DIR pins the cache to a known path; the `prefetch` stage bakes it
# into the image there (no cache mount) so the runtime `uv sync` resolves
# offline. UV_LINK_MODE=copy lets that runtime venv copy out of the baked
# (read-only) cache layer.
ENV UV_HTTP_TIMEOUT=500 \
    UV_INDEX_STRATEGY="unsafe-best-match" \
    UV_LINK_MODE=copy \
    UV_CACHE_DIR=/root/.cache/uv

# Enable CUDA forward compatibility by setting '-e VLLM_ENABLE_CUDA_COMPATIBILITY=1'.
# Only needed for datacenter/professional GPUs with older drivers.
# See: https://docs.nvidia.com/deploy/cuda-compatibility/
ENV VLLM_ENABLE_CUDA_COMPATIBILITY=0

# ---------------------------------------------------------------------------
# deps: dependency metadata only (pyproject.toml + uv.lock) plus the uv driver.
# Copying these *before* the full source keeps the expensive `prefetch` cache
# bake below from being invalidated by unrelated source edits — it rebuilds
# only when the dependencies actually change. (Verified sufficient: `uv sync
# --frozen --no-install-project` needs only these two files.)
# ---------------------------------------------------------------------------
FROM base AS deps
WORKDIR /workspace/verl
COPY pyproject.toml uv.lock manage_envs.py ./

# ---------------------------------------------------------------------------
# prefetch: BAKE the cu12.9 uv cache into the image. `manage_envs.py prefetch
# cu129` syncs the conflict-free covering combos (veomni, then nemoautomodel)
# into throwaway envs purely to fill UV_CACHE_DIR (/root/.cache/uv) with every
# wheel & built artifact those backends need from uv.lock — flash-attn 2.8.3 is
# source-compiled against torch 2.9.1 here, once. The `cu129` scope keeps this
# image to its own torch world: the universal lock also holds the torch-2.11
# backends, but those are baked by Dockerfile.uv.cu130 and must not be built
# against this CUDA-12.9 toolkit. It passes --no-install-project, so only deps
# are cached and this layer is independent of the verl source tree. NOTE:
# unlike every other uv step there is deliberately NO `--mount=type=cache`
# here, so the warmed cache is committed as an image layer and ships *inside*
# the image; the runtime `uv sync` then resolves from it offline.
# ---------------------------------------------------------------------------
FROM deps AS prefetch
RUN python3 manage_envs.py prefetch cu129 -- --frozen

# ---------------------------------------------------------------------------
# source / lock: full source tree, used only to (re)generate the universal
# uv.lock (the same lock the cu130 image uses). Build `--target=lock` to
# refresh the lockfile and copy it back out:
#
#     docker build -f docker/Dockerfile.uv.cu129 --target=lock -t verl:uv-cu129-lock .
#     docker create --name verl-tmp verl:uv-cu129-lock
#     docker cp verl-tmp:/workspace/verl/uv.lock ./uv.lock
#     docker rm verl-tmp
# ---------------------------------------------------------------------------
FROM base AS source
WORKDIR /workspace/verl
COPY . /workspace/verl

FROM source AS lock
RUN --mount=type=cache,target=/root/.cache/uv,id=verl-uv-cache \
    python3 manage_envs.py lock

# ---------------------------------------------------------------------------
# final: the runtime image. Inherits the baked cu12.9 uv cache from `prefetch`,
# adds the verl source, and bakes NO fixed .venv. The container starts in a
# shell; materialize the backend you want with `manage_envs.py sync` — it
# `uv sync`s the requested extra into /workspace/verl/.venv from the baked
# cache (fast / offline, no network). That venv's bin is already on PATH, so it
# activates in place. Pick one of veomni / nemoautomodel (they conflict; see
# [tool.uv].conflicts), e.g.:
#
#     docker run --rm -it --gpus all verl:uv-cu129 bash
#     # then, inside the container:
#     python3 manage_envs.py sync nemoautomodel -- --frozen
#     python3 -m verl.trainer.main_ppo ...
#
# The cuDNN / NCCL pip wheels installed by that sync (nvidia-cudnn-cu12 /
# nvidia-nccl-cu12, from torch's transitive pins + the cudnn override) must
# match the apt debs above.
# ---------------------------------------------------------------------------
FROM prefetch AS final
COPY . /workspace/verl
ENV VIRTUAL_ENV="/workspace/verl/.venv" \
    PATH="/workspace/verl/.venv/bin:${PATH}"
CMD ["bash"]
