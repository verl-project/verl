# Docker image for GB200 NVL4 (aarch64, Blackwell SM=100) with vLLM
# Based on Dockerfile.stable.vllm with GB200-specific fixes.
#
# GB200-specific changes vs Dockerfile.stable.vllm:
#   1. vllm==0.17.0              — install via pip instead of building from source
#   2. transformers==4.57.1      — pin; avoid >=5.0 incompatibility
#   3. trl<0.15                  — trl 0.15+ removed AutoModelForCausalLMWithValueHead
#   4. cachetools                — missing in some base environments
#
# Build:
#   docker build -f docker/Dockerfile.vllm.gb200 -t verl:vllm-gb200 .

FROM nvidia/cuda:12.9.1-devel-ubuntu24.04

ARG DEBIAN_FRONTEND=noninteractive
ARG PIP_NO_CACHE_DIR=1

# PEP 668: Ubuntu 24.04 blocks system-wide pip installs; override for Docker
ENV PIP_BREAK_SYSTEM_PACKAGES=1

# Ubuntu 24.04 ships python3.12 natively — no PPA needed
RUN apt-get update && apt-get install -y \
    git \
    wget \
    cmake \
    build-essential \
    libibverbs-dev \
    libnuma-dev \
    librdmacm-dev \
    numactl \
    python3.12 \
    python3.12-dev \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.12 /usr/bin/python3 && \
    ln -sf /usr/bin/python3.12 /usr/bin/python

RUN wget https://bootstrap.pypa.io/get-pip.py && \
    python3.12 get-pip.py && \
    rm get-pip.py

# Install CUDA torch first so vllm builds against it
# use torch2.9.1+cudnn9.16 to avoid conflict
RUN pip install torch==2.9.1 torchvision torchaudio --index-url https://download.pytorch.org/whl/cu129
RUN sed -i '/nvidia-cudnn-cu12/d' /usr/local/lib/python3.12/dist-packages/torch-2.9.1+cu129.dist-info/METADATA
RUN pip install --no-deps --force-reinstall nvidia-cudnn-cu12==9.16.0.29

# Build vllm v0.17.0 from source against torch 2.9.1 to avoid ABI mismatch
RUN git clone --depth 1 -b v0.17.0 https://github.com/vllm-project/vllm.git && \
    cd vllm && \
    find requirements -name "*.txt" -print0 | xargs -0 sed -i '/torch/d' && \
    pip install -r requirements/build.txt && \
    pip install -e . --no-build-isolation --no-deps && \
    pip install -r requirements/cuda.txt

RUN pip install pybind11 wheel

RUN pip install nvidia-mathdx

RUN MAX_JOBS=128 pip install -v --disable-pip-version-check --no-build-isolation --config-settings "--build-option=--cpp_ext" --config-settings "--build-option=--cuda_ext" git+https://github.com/NVIDIA/apex.git

RUN export NVTE_FRAMEWORK=pytorch && \
    export CUDNN_PATH=/usr/local/lib/python3.12/dist-packages/nvidia/cudnn && \
    export CPATH="${CUDNN_PATH}/include:${CPATH}" && \
    export LD_LIBRARY_PATH="${CUDNN_PATH}/lib:${LD_LIBRARY_PATH}" && \
    MAX_JOBS=128 NVTE_BUILD_THREADS_PER_JOB=4 pip3 install --resume-retries 999 --no-build-isolation git+https://github.com/NVIDIA/TransformerEngine.git@release_v2.10

# GB200 fix 1: pin transformers — avoid >=5.0 incompatibility
RUN pip install --no-cache-dir transformers==4.57.1 tokenizers

RUN pip install codetiming tensordict mathruler pylatexenc qwen_vl_utils cachetools

RUN pip install flash_attn==2.8.1 --no-build-isolation

RUN NSIGHT_VERSION=2025.6.1_2025.6.1.190-1_$(if [ "$(uname -m)" = "aarch64" ]; then echo "arm64"; else echo "amd64"; fi) && \
    wget https://developer.nvidia.com/downloads/assets/tools/secure/nsight-systems/2025_6/nsight-systems-${NSIGHT_VERSION}.deb && \
    apt-get update && apt-get install -y libxcb-cursor0 && \
    apt-get install -y ./nsight-systems-${NSIGHT_VERSION}.deb && \
    rm -rf /usr/local/cuda/bin/nsys && \
    ln -s /opt/nvidia/nsight-systems/2025.6.1/nsys  /usr/local/cuda/bin/nsys && \
    rm -rf /usr/local/cuda/bin/nsys-ui && \
    ln -s /opt/nvidia/nsight-systems/2025.6.1/nsys-ui /usr/local/cuda/bin/nsys-ui && \
    rm nsight-systems-${NSIGHT_VERSION}.deb && \
    rm -rf /var/lib/apt/lists/*

# GB200 fix 2: trl 0.15+ removed AutoModelForCausalLMWithValueHead
RUN pip3 install --no-cache-dir --no-deps "trl<0.15"

RUN pip3 install nvtx matplotlib liger_kernel

RUN pip install -U git+https://github.com/ISEEKYAN/mbridge.git

RUN pip install --no-deps --no-cache-dir git+https://github.com/NVIDIA/Megatron-LM.git@core_v0.15.0

RUN pip install git+https://github.com/volcengine/verl.git@v0.6.0 && \
    pip uninstall -y verl
